# Server configuration
PORT=3001

# Somnia Testnet RPC
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_WS_URL=wss://dream-rpc.somnia.network/ws

# Contract address (required, non-zero)
GAME_CONTRACT_ADDRESS=

# Orchestrator private key (required for timeout force-start and submitGameResult)
# WARNING: Never commit real private keys!
ORCHESTRATOR_PRIVATE_KEY=

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000
