# Server configuration
PORT=3001

# Somnia Testnet RPC (Ankr is more reliable than the default Somnia RPC)
SOMNIA_RPC_URL=https://rpc.ankr.com/somnia_testnet
SOMNIA_WS_URL=wss://dream-rpc.somnia.network/ws

# Contract address (REQUIRED - replace with your deployed PixelRoyale contract)
GAME_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_PIXEL_ROYALE_CONTRACT

# Orchestrator private key (used to submit game results on-chain)
# WARNING: Never commit real private keys!
ORCHESTRATOR_PRIVATE_KEY=0xYOUR_ORCHESTRATOR_PRIVATE_KEY

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Password required by the status page redeploy button
REDEPLOY_PASSWORD=replace_with_a_strong_secret
